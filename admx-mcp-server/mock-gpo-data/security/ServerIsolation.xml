<Registry clsid="{9CD4B2F4-923D-47f5-A062-E897DD1DAD50}" name="Enable PMTU Discovery" status="EnablePMTUDiscovery" image="12" changed="2026-01-09 19:05:52" uid="{52C38FD7-A081-404C-A8EA-B24A9614D0B5}" desc="&lt;b&gt;Enable PMTU Discovery&lt;/b&gt;&lt;p&gt;             This setting configures whether computers can use PMTU             discovery on the network.&lt;p&gt;             &lt;b&gt;1&lt;/b&gt; --  Enable&lt;br&gt;             &lt;b&gt;0&lt;/b&gt; --  Disable" bypassErrors="1">
